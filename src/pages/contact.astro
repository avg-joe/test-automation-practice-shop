---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm';
import { getTestId } from '../utils/testId';
---

<Layout title="Test Automation Practice Shop – Contact">
  
  <!-- PAGE HEADER -->
  <div
    data-testid={getTestId('page-header')}
    class="page-header"
  >
    <h1 class="page-header__title">Get In Touch</h1>
    <p class="page-header__subtitle">
      Have a question or need help? We're here for you 24/7.
    </p>
  </div>

  <!-- CONTACT CARDS -->
  <div
    data-testid={getTestId('contact-cards')}
    class="contact-cards"
  >
    <div
      data-testid={getTestId('contact-card-chat')}
      class="contact-card"
    >
      <div class="contact-card__icon">💬</div>
      <h3 class="contact-card__title">Live Chat</h3>
      <p class="contact-card__desc">
        Chat with our support team in real time. Average response: under 2 minutes.
      </p>
      <a
        href="#"
        data-testid={getTestId('start-chat-btn')}
        class="contact-card__link"
      >
        Start a Chat
      </a>
    </div>

    <div
      data-testid={getTestId('contact-card-email')}
      class="contact-card"
    >
      <div class="contact-card__icon">📧</div>
      <h3 class="contact-card__title">Email Support</h3>
      <p class="contact-card__desc">
        Send us an email and we'll get back to you within 24 hours.
      </p>
      <a
        href="mailto:support@testautopracticeshop.com.au"
        data-testid={getTestId('email-link')}
        class="contact-card__link"
      >
        support@testautopracticeshop.com.au
      </a>
    </div>

    <div
      data-testid={getTestId('contact-card-phone')}
      class="contact-card"
    >
      <div class="contact-card__icon">📞</div>
      <h3 class="contact-card__title">Phone</h3>
      <p class="contact-card__desc">
        Call us Mon–Fri, 9am–5pm AEDT. We're happy to help!
      </p>
      <a
        href="tel:+61296851234"
        data-testid={getTestId('phone-link')}
        class="contact-card__link"
      >
        +61 2 9685 1234
      </a>
    </div>
  </div>

  <!-- MAIN CONTACT LAYOUT -->
  <div class="contact-main">
    
    <!-- CONTACT FORM -->
    <ContactForm client:load />

    <!-- CONTACT INFO -->
    <div data-testid={getTestId('contact-info-section')}>
      <h2 class="contact-info__title">Our Information</h2>
      <p class="contact-info__subtitle">You can also find us at the details below.</p>

      <div
        data-testid={getTestId('info-address')}
        class="contact-info__item"
      >
        <div class="contact-info__icon-box">
          📍
        </div>
        <div>
          <h4 class="contact-info__label">Head Office</h4>
          <p class="contact-info__text">
            123 George Street, Suite 500<br />Sydney, NSW 2000, Australia
          </p>
        </div>
      </div>

      <div
        data-testid={getTestId('info-hours')}
        class="contact-info__item"
      >
        <div class="contact-info__icon-box">
          🕐
        </div>
        <div>
          <h4 class="contact-info__label">Business Hours</h4>
          <p class="contact-info__text">
            Mon – Fri: 9:00 AM – 5:00 PM AEDT<br />
            Sat: 10:00 AM – 2:00 PM AEDT<br />
            Sun: Closed
          </p>
        </div>
      </div>

      <div
        data-testid={getTestId('info-support')}
        class="contact-info__item"
      >
        <div class="contact-info__icon-box">
          🛟
        </div>
        <div>
          <h4 class="contact-info__label">Online Support</h4>
          <p class="contact-info__text">
            Live chat available 24/7<br />
            Email support: response within 24 hrs
          </p>
        </div>
      </div>

      <div
        data-testid={getTestId('map-placeholder')}
        class="contact-info__map"
      >
        <span class="contact-info__map-icon">🗺️</span>
        <p class="contact-info__map-text">Map Preview — 123 George St, Sydney, NSW</p>
      </div>

      <div
        data-testid={getTestId('social-section')}
        class="contact-info__social"
      >
        <h4 class="contact-info__social-title">Follow Us</h4>
        <div class="contact-info__social-links">
          <a
            href="#"
            data-testid={getTestId('social-instagram')}
            aria-label="Instagram"
            class="contact-info__social-link"
          >
            📸
          </a>
          <a
            href="#"
            data-testid={getTestId('social-twitter')}
            aria-label="Twitter"
            class="contact-info__social-link"
          >
            🐦
          </a>
          <a
            href="#"
            data-testid={getTestId('social-facebook')}
            aria-label="Facebook"
            class="contact-info__social-link"
          >
            📘
          </a>
          <a
            href="#"
            data-testid={getTestId('social-youtube')}
            aria-label="YouTube"
            class="contact-info__social-link"
          >
            ▶️
          </a>
        </div>
      </div>
    </div>

  </div>

  <!-- FAQ -->
  <div
    data-testid={getTestId('faq-section')}
    class="faq-section"
  >
    <h2 class="faq-section__title">
      Frequently Asked Questions
    </h2>
    <div
      data-testid={getTestId('faq-grid')}
      class="faq-grid"
    >
      
      <details
        data-testid={getTestId('faq-1')}
        class="faq-item"
      >
        <summary
          data-testid={getTestId('faq-question-1')}
          class="faq-item__question"
        >
          How long does shipping take? <span class="faq-item__toggle">＋</span>
        </summary>
        <div
          data-testid={getTestId('faq-answer-1')}
          class="faq-item__answer"
        >
          Standard shipping takes 3–5 business days. Express shipping (1–2 days) is available at checkout.
        </div>
      </details>

      <details
        data-testid={getTestId('faq-2')}
        class="faq-item"
      >
        <summary
          data-testid={getTestId('faq-question-2')}
          class="faq-item__question"
        >
          What is your return policy? <span class="faq-item__toggle">＋</span>
        </summary>
        <div
          data-testid={getTestId('faq-answer-2')}
          class="faq-item__answer"
        >
          We offer a 30-day hassle-free return policy. Items must be in original condition.
        </div>
      </details>

      <details
        data-testid={getTestId('faq-3')}
        class="faq-item"
      >
        <summary
          data-testid={getTestId('faq-question-3')}
          class="faq-item__question"
        >
          How do I track my order? <span class="faq-item__toggle">＋</span>
        </summary>
        <div
          data-testid={getTestId('faq-answer-3')}
          class="faq-item__answer"
        >
          After your order ships, you'll receive an email with a tracking number. Visit the carrier's site to track.
        </div>
      </details>

      <details
        data-testid={getTestId('faq-4')}
        class="faq-item"
      >
        <summary
          data-testid={getTestId('faq-question-4')}
          class="faq-item__question"
        >
          Do you ship internationally? <span class="faq-item__toggle">＋</span>
        </summary>
        <div
          data-testid={getTestId('faq-answer-4')}
          class="faq-item__answer"
        >
          Yes! We ship to 50+ countries. International shipping rates and times vary by location.
        </div>
      </details>

    </div>
  </div>

  <!-- FOOTER -->
  <footer
    data-testid={getTestId('footer')}
    class="footer"
  >
    <div class="footer__grid">
      <div>
        <h3 class="footer__brand-title">
          Test Automation Practice <span class="footer__brand-accent">Shop</span>
        </h3>
        <p class="footer__brand-desc">
          Your one-stop destination for quality products at unbeatable prices.
        </p>
      </div>
      <div>
        <h4 class="footer__column-title">Shop</h4>
        <ul class="footer__list">
          <li class="footer__list-item">
            <a href="/shop" data-testid={getTestId('footer-shop-all-products')} class="footer__link">All Products</a>
          </li>
          <li class="footer__list-item">
            <a href="#" data-testid={getTestId('footer-shop-electronics')} class="footer__link">Electronics</a>
          </li>
          <li class="footer__list-item">
            <a href="#" data-testid={getTestId('footer-shop-fashion')} class="footer__link">Fashion</a>
          </li>
          <li class="footer__list-item">
            <a href="#" data-testid={getTestId('footer-shop-sale')} class="footer__link">Sale</a>
          </li>
        </ul>
      </div>
      <div>
        <h4 class="footer__column-title">Support</h4>
        <ul class="footer__list">
          <li class="footer__list-item">
            <a href="/contact" data-testid={getTestId('footer-support-contact-us')} class="footer__link">Contact Us</a>
          </li>
          <li class="footer__list-item">
            <a href="#" data-testid={getTestId('footer-support-faq')} class="footer__link">FAQ</a>
          </li>
          <li class="footer__list-item">
            <a href="#" data-testid={getTestId('footer-support-returns')} class="footer__link">Returns</a>
          </li>
          <li class="footer__list-item">
            <a href="#" data-testid={getTestId('footer-support-shipping')} class="footer__link">Shipping</a>
          </li>
        </ul>
      </div>
      <div>
        <h4 class="footer__column-title">Account</h4>
        <ul class="footer__list">
          <li class="footer__list-item">
            <a href="#" id="footer-login-link" data-testid={getTestId('footer-account-login')} class="footer__link">Login</a>
          </li>
          <li class="footer__list-item">
            <a href="#" data-testid={getTestId('footer-account-register')} class="footer__link">Register</a>
          </li>
          <li class="footer__list-item">
            <a href="#" data-testid={getTestId('footer-account-my-orders')} class="footer__link">My Orders</a>
          </li>
          <li class="footer__list-item">
            <a href="#" data-testid={getTestId('footer-account-wishlist')} class="footer__link">Wishlist</a>
          </li>
        </ul>
      </div>
    </div>
    <div class="footer__bottom">
      <span>© 2026 Test Automation Practice Shop. All rights reserved.</span>
      <span>Privacy Policy · Terms of Service</span>
    </div>
  </footer>

  <script>
    // Allow footer login link to open the login modal
    document.getElementById('footer-login-link')?.addEventListener('click', (e) => {
      e.preventDefault();
      document.getElementById('open-login-modal')?.click();
    });
  </script>

</Layout>
