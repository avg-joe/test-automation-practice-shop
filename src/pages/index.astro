---
import Layout from '../layouts/Layout.astro';
import AddToCart from '../components/AddToCart';
import { getTestId } from '../utils/testId';

const products = [
  { id: '1', name: 'Air Runner Pro', price: 89, emoji: '👟', category: 'Footwear', badge: 'Sale', originalPrice: 120 },
  { id: '2', name: 'SoundMax Headphones', price: 149, emoji: '🎧', category: 'Electronics', badge: null, originalPrice: null },
  { id: '3', name: 'Urban Tote Bag', price: 65, emoji: '👜', category: 'Accessories', badge: 'New', originalPrice: null },
  { id: '4', name: 'SmartWatch Series 5', price: 199, emoji: '⌚', category: 'Electronics', badge: null, originalPrice: null },
];
---

<Layout title="Test Automation Practice Shop – Home">

  <!-- HERO -->
  <section
    data-testid={getTestId('hero-section')}
    class="hero"
  >
    <div class="hero__content">
      <span
        data-testid={getTestId('hero-badge')}
        class="hero__badge"
      >
        New Season 2026
      </span>
      <h1
        data-testid={getTestId('hero-title')}
        class="hero__title"
      >
        Discover Products You&apos;ll <span class="hero__title-accent">Love</span>
      </h1>
      <p
        data-testid={getTestId('hero-subtitle')}
        class="hero__subtitle"
      >
        Curated collections of top-quality items delivered straight to your door. Shop with confidence.
      </p>
      <div class="hero__actions">
        <a
          href="/shop"
          data-testid={getTestId('hero-shop-btn')}
          class="hero__btn hero__btn--primary"
        >
          Shop Now
        </a>
        <a
          href="#featured-products"
          data-testid={getTestId('hero-explore-btn')}
          class="hero__btn hero__btn--outline"
        >
          Explore Deals
        </a>
      </div>
    </div>
    <div
      data-testid={getTestId('hero-image')}
      class="hero__image"
    >
      🛍️
    </div>
  </section>

  <!-- FEATURES BAR -->
  <div
    data-testid={getTestId('features-bar')}
    class="features-bar"
  >
    <div
      data-testid={getTestId('feature-shipping')}
      class="feature"
    >
      <span class="feature__icon">🚚</span>
      <div>
        <h4 class="feature__title">Free Shipping</h4>
        <p class="feature__desc">On orders over $50</p>
      </div>
    </div>
    <div
      data-testid={getTestId('feature-returns')}
      class="feature"
    >
      <span class="feature__icon">↩️</span>
      <div>
        <h4 class="feature__title">Easy Returns</h4>
        <p class="feature__desc">30-day return policy</p>
      </div>
    </div>
    <div
      data-testid={getTestId('feature-support')}
      class="feature"
    >
      <span class="feature__icon">💬</span>
      <div>
        <h4 class="feature__title">24/7 Support</h4>
        <p class="feature__desc">We're always here for you</p>
      </div>
    </div>
  </div>

  <!-- FEATURED PRODUCTS -->
  <section id="featured-products" data-testid={getTestId('featured-products')} class="section">
    <div class="section__header">
      <h2 class="section__title">Featured Products</h2>
      <a
        href="/shop"
        data-testid={getTestId('view-all-products')}
        class="section__link"
      >
        View All →
      </a>
    </div>

    <div data-testid={getTestId('product-grid')} class="product-grid">
      {products.map((product) => (
        <div
          data-testid={getTestId(`product-card-${product.id}`)}
          class="product-card"
        >
          <div class="product-card__image">
            {product.emoji}
            {product.badge && (
              <span class="product-card__badge">
                {product.badge}
              </span>
            )}
          </div>
          <div class="product-card__content">
            <p class="product-card__category">{product.category}</p>
            <h3 class="product-card__name">{product.name}</h3>
            <div class="product-card__footer">
              <span
                data-testid={getTestId(`product-price-${product.id}`)}
                class="product-card__price"
              >
                ${product.price}
                {product.originalPrice && (
                  <del class="product-card__price-original">${product.originalPrice}</del>
                )}
              </span>
              <AddToCart
                client:visible
                productId={product.id}
                productName={product.name}
                price={product.price}
                emoji={product.emoji}
                testIdSuffix={product.id}
              />
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CATEGORIES -->
  <section
    data-testid={getTestId('categories-section')}
    class="section section--light"
  >
    <div class="section__header">
      <h2 class="section__title">Shop by Category</h2>
      <a
        href="/shop"
        data-testid={getTestId('view-all-categories')}
        class="section__link"
      >
        Browse All →
      </a>
    </div>
    <div data-testid={getTestId('category-grid')} class="category-grid">
      <div
        data-testid={getTestId('category-electronics')}
        class="category-card"
      >
        <span class="category-card__icon">📱</span>
        <h3 class="category-card__title">Electronics</h3>
        <p class="category-card__count">120+ items</p>
      </div>
      <div
        data-testid={getTestId('category-fashion')}
        class="category-card"
      >
        <span class="category-card__icon">👗</span>
        <h3 class="category-card__title">Fashion</h3>
        <p class="category-card__count">340+ items</p>
      </div>
      <div
        data-testid={getTestId('category-home')}
        class="category-card"
      >
        <span class="category-card__icon">🏠</span>
        <h3 class="category-card__title">Home &amp; Living</h3>
        <p class="category-card__count">210+ items</p>
      </div>
      <div
        data-testid={getTestId('category-sports')}
        class="category-card"
      >
        <span class="category-card__icon">⚽</span>
        <h3 class="category-card__title">Sports</h3>
        <p class="category-card__count">95+ items</p>
      </div>
    </div>
  </section>

  <!-- PROMO BANNER -->
  <section class="section">
    <div
      data-testid={getTestId('promo-banner')}
      class="promo-banner"
    >
      <div class="promo-banner__content">
        <h2>Summer Sale — Up to 40% Off!</h2>
        <p>Deals refreshed daily. Don&apos;t miss out on limited stock.</p>
        <a
          href="/shop"
          data-testid={getTestId('banner-shop-btn')}
          class="promo-banner__btn"
        >
          Shop the Sale
        </a>
      </div>
      <div class="promo-banner__icon">🏷️</div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section
    data-testid={getTestId('testimonials-section')}
    class="section section--light"
  >
    <div class="section__header">
      <h2 class="section__title">What Our Customers Say</h2>
    </div>
    <div data-testid={getTestId('testimonial-grid')} class="testimonial-grid">
      <div
        data-testid={getTestId('testimonial-1')}
        class="testimonial-card"
      >
        <div class="testimonial-card__stars">★★★★★</div>
        <p class="testimonial-card__text">"Test Automation Practice Shop has the best deals and the checkout is so quick. I've ordered 10 times this year alone!"</p>
        <div class="testimonial-card__author">
          <div class="testimonial-card__avatar">JD</div>
          <div>
            <h4 class="testimonial-card__name">Jane D.</h4>
            <p class="testimonial-card__badge">Verified Buyer</p>
          </div>
        </div>
      </div>
      <div
        data-testid={getTestId('testimonial-2')}
        class="testimonial-card"
      >
        <div class="testimonial-card__stars">★★★★★</div>
        <p class="testimonial-card__text">"Incredible product quality. Returns are seamless and customer support responds within minutes."</p>
        <div class="testimonial-card__author">
          <div class="testimonial-card__avatar">MK</div>
          <div>
            <h4 class="testimonial-card__name">Mark K.</h4>
            <p class="testimonial-card__badge">Verified Buyer</p>
          </div>
        </div>
      </div>
      <div
        data-testid={getTestId('testimonial-3')}
        class="testimonial-card"
      >
        <div class="testimonial-card__stars">★★★★☆</div>
        <p class="testimonial-card__text">"Love the variety. Everything arrived fast and well-packaged. Highly recommend Test Automation Practice Shop!"</p>
        <div class="testimonial-card__author">
          <div class="testimonial-card__avatar">SP</div>
          <div>
            <h4 class="testimonial-card__name">Sara P.</h4>
            <p class="testimonial-card__badge">Verified Buyer</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer data-testid={getTestId('footer')} class="footer">
    <div class="footer__grid">
      <div>
        <h3 class="footer__brand-title">Test Automation Practice <span class="footer__brand-accent">Shop</span></h3>
        <p class="footer__brand-desc">Your one-stop destination for quality products at unbeatable prices.</p>
      </div>
      <div>
        <h4 class="footer__column-title">Shop</h4>
        <ul class="footer__list">
          <li class="footer__list-item"><a href="/shop" class="footer__link">All Products</a></li>
          <li class="footer__list-item"><a href="#" class="footer__link">Electronics</a></li>
          <li class="footer__list-item"><a href="#" class="footer__link">Fashion</a></li>
          <li class="footer__list-item"><a href="#" class="footer__link">Sale</a></li>
        </ul>
      </div>
      <div>
        <h4 class="footer__column-title">Support</h4>
        <ul class="footer__list">
          <li class="footer__list-item"><a href="/contact" class="footer__link">Contact Us</a></li>
          <li class="footer__list-item"><a href="#" class="footer__link">FAQ</a></li>
          <li class="footer__list-item"><a href="#" class="footer__link">Returns</a></li>
          <li class="footer__list-item"><a href="#" class="footer__link">Shipping</a></li>
        </ul>
      </div>
      <div>
        <h4 class="footer__column-title">Account</h4>
        <ul class="footer__list">
          <li class="footer__list-item"><a href="#" id="footer-login-link" class="footer__link">Login</a></li>
          <li class="footer__list-item"><a href="#" class="footer__link">Register</a></li>
          <li class="footer__list-item"><a href="#" class="footer__link">My Orders</a></li>
          <li class="footer__list-item"><a href="#" class="footer__link">Wishlist</a></li>
        </ul>
      </div>
    </div>
    <div class="footer__bottom">
      <span>© 2026 Test Automation Practice Shop. All rights reserved.</span>
      <span>Privacy Policy · Terms of Service</span>
    </div>
  </footer>

  <script>
    // Allow footer login link to open the login modal
    document.getElementById('footer-login-link')?.addEventListener('click', (e) => {
      e.preventDefault();
      document.getElementById('open-login-modal')?.click();
    });
  </script>

</Layout>
