---
import Layout from '../layouts/Layout.astro';
import CheckoutSteps from '../components/CheckoutSteps.astro';
import CartPage from '../components/CartPage';
import Footer from '../components/Footer.astro';
import { getTestId } from '../utils/testId';
---

<Layout title="Your Cart – Test Automation Practice Shop">
  <div class="cart-header" data-testid={getTestId('page-header')}>
    <p class="cart-header__breadcrumb">
      <a href="/">Home</a> › <a href="/shop">Shop</a> › Cart
    </p>
    <h1 class="cart-header__title">Your Cart</h1>
  </div>

  <CheckoutSteps activeStep="cart" />

  <CartPage client:only="react" />

  <Footer />
</Layout>
